// Prisma schema for Taxi Meik SWE
// Car rental marketplace connecting taxi car owners with drivers in Myanmar

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  DRIVER
  OWNER
  ADMIN
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  FREEZE
}

enum FuelType {
  PETROL
  DIESEL
  EV
}

enum RentalPaymentType {
  DAILY
  WEEKLY
  MONTHLY
}

enum RentalType {
  DRIVER_HOME
  OWNER_HOME
}

enum CarAvailabilityStatus {
  AVAILABLE
  RENTED
  UNAVAILABLE
}

enum RentalStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum OTPPurpose {
  REGISTER
  LOGIN
  PASSWORD_RESET
}

enum ReviewDirection {
  OWNER_TO_DRIVER
  DRIVER_TO_OWNER
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id                  String             @id @default(uuid()) @db.Uuid
  email               String             @unique
  phone               String?            @unique
  passwordHash        String?            @map("password_hash")
  name                String             @map("full_name")
  role                Role
  profilePhoto        String?            @map("profile_photo")
  nrcNumber           String?            @unique @map("nrc_number")
  nrcDocumentUrl      String?            @map("nrc_document_url")
  isVerified          Boolean            @default(false) @map("is_verified")
  verificationStatus  VerificationStatus @default(PENDING) @map("verification_status")
  isActive            Boolean            @default(true) @map("is_active")
  city                String?
  township            String?
  address             String?
  emailVerified       Boolean            @default(false) @map("email_verified")
  image               String?
  phoneNumberVerified Boolean            @default(false) @map("phone_number_verified")
  createdAt           DateTime           @default(now()) @map("created_at")
  updatedAt           DateTime           @updatedAt @map("updated_at")

  driverProfile DriverProfile?
  ownerProfile  OwnerProfile?
  driverLicense DriverLicense?

  ownedCars Car[] @relation("OwnerCars")

  driverApplications CarApplication[] @relation("DriverApplications")
  ownerApplications  CarApplication[] @relation("OwnerApplications")

  driverRentals CarRental[] @relation("DriverRentals")
  ownerRentals  CarRental[] @relation("OwnerRentals")

  notificationsReceived  Notification[] @relation("NotificationReceiver")
  notificationsTriggered Notification[] @relation("NotificationTrigger")

  sentReviews     Review[] @relation("Reviewer")
  receivedReviews Review[] @relation("ReviewTarget")

  otpCodes       OTPCode[]
  trustedDevices TrustedDevice[]
  sessions       Session[]
  accounts       Account[]

  @@map("users")
}

model DriverProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  address            String?
  nrcText            String @map("nrc_text")
  nrcFrontImage      String @map("nrc_front_image")
  nrcBackImage       String @map("nrc_back_image")
  driverLicenseImage String? @map("driver_license_image")

  nrcFrontUrl        String?            @map("nrc_front_url")
  nrcBackUrl         String?            @map("nrc_back_url")
  selfieUrl          String?            @map("selfie_url")
  drivingLicenseUrl  String?            @map("driving_license_url")
  drivingLicenseFrontUrl String?        @map("driving_license_front_url")
  drivingLicenseBackUrl  String?        @map("driving_license_back_url")
  kycStatus          String             @default("PENDING") @map("kyc_status")

  adminApprovalStatus ApprovalStatus @default(PENDING) @map("admin_approval_status")
  approvedAt          DateTime?      @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("driver_profiles")
}

model OwnerProfile {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @map("user_id") @db.Uuid

  address       String?
  nrcText       String @map("nrc_text")
  nrcFrontImage String @map("nrc_front_image")
  nrcBackImage  String @map("nrc_back_image")

  adminApprovalStatus ApprovalStatus @default(PENDING) @map("admin_approval_status")
  approvedAt          DateTime?      @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("owner_profiles")
}

model DriverLicense {
  id              String             @id @default(uuid()) @db.Uuid
  userId          String             @unique @map("user_id") @db.Uuid
  licenseNumber   String             @unique @map("license_number")
  licenseClass    String             @map("license_class")
  expiryDate      DateTime           @map("expiry_date")
  documentUrl     String             @map("document_url")
  yearsExperience Int?               @map("years_experience")
  status          VerificationStatus @default(PENDING)
  verifiedAt      DateTime?          @map("verified_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("driver_licenses")
}

model Car {
  id      String @id @default(uuid()) @db.Uuid
  ownerId String @map("owner_id") @db.Uuid

  color  String?
  rating Float   @default(0)

  year  Int?
  brand String
  model String

  licenseNumber String @unique @map("license_number")

  fuelType FuelType @map("fuel_type")

  ownerBook String @map("owner_book")

  rentalPeriod      String?           @map("rental_period")
  rentalPaymentType RentalPaymentType @map("rental_payment_type")
  rentalType        RentalType        @map("rental_type")

  rentalPrice   Decimal @db.Decimal(12, 2) @map("rental_price")
  depositAmount Decimal @default(0) @db.Decimal(12, 2) @map("deposit_amount")

  availabilityStatus CarAvailabilityStatus @default(AVAILABLE) @map("availability_status")

  adminApprovalStatus ApprovalStatus @default(PENDING) @map("admin_approval_status")
  approvedAt          DateTime?      @map("approved_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner User @relation("OwnerCars", fields: [ownerId], references: [id], onDelete: Cascade)

  carImages    CarImage?
  applications CarApplication[]
  rentals      CarRental[]
  reviews      Review[]

  @@index([ownerId])
  @@map("cars")
}

model CarImage {
  id    String @id @default(uuid()) @db.Uuid
  carId String @unique @map("car_id") @db.Uuid

  frontImage String @map("front_image")
  backImage  String @map("back_image")
  leftImage  String @map("left_image")
  rightImage String @map("right_image")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  car Car @relation(fields: [carId], references: [id], onDelete: Cascade)

  @@map("car_images")
}

model CarApplication {
  id String @id @default(uuid()) @db.Uuid

  ownerId  String @map("owner_id") @db.Uuid
  carId    String @map("car_id") @db.Uuid
  driverId String @map("driver_id") @db.Uuid

  wardRecommendationLetter String? @map("ward_recommendation_letter")

  ownerApprovalStatus ApprovalStatus @default(PENDING) @map("owner_approval_status")
  adminApprovalStatus ApprovalStatus @default(PENDING) @map("admin_approval_status")

  approvedAt DateTime? @map("approved_at")
  agreementSentAt DateTime? @map("agreement_sent_at")
  ownerAgreementAgreedAt DateTime? @map("owner_agreement_agreed_at")
  driverAgreementAgreedAt DateTime? @map("driver_agreement_agreed_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  owner  User @relation("OwnerApplications", fields: [ownerId], references: [id], onDelete: Cascade)
  driver User @relation("DriverApplications", fields: [driverId], references: [id], onDelete: Cascade)

  car    Car        @relation(fields: [carId], references: [id], onDelete: Cascade)
  rental CarRental?

  @@unique([carId, driverId])
  @@index([driverId])
  @@index([ownerId])
  @@map("car_applications")
}

model CarRental {
  id String @id @default(uuid()) @db.Uuid

  carApplicationId String @unique @map("car_application_id") @db.Uuid

  carId    String @map("car_id") @db.Uuid
  ownerId  String @map("owner_id") @db.Uuid
  driverId String @map("driver_id") @db.Uuid

  rentalStartDate DateTime @map("rental_start_date")
  rentalEndDate   DateTime @map("rental_end_date")

  status RentalStatus @default(ACTIVE)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  application CarApplication @relation(fields: [carApplicationId], references: [id], onDelete: Cascade)

  car     Car      @relation(fields: [carId], references: [id], onDelete: Cascade)
  owner   User     @relation("OwnerRentals", fields: [ownerId], references: [id], onDelete: Cascade)
  driver  User     @relation("DriverRentals", fields: [driverId], references: [id], onDelete: Cascade)
  reviews Review[]

  @@index([driverId])
  @@index([carId])
  @@map("car_rentals")
}

model OTPCode {
  id String @id @default(uuid()) @db.Uuid

  userId   String?    @map("user_id") @db.Uuid
  phone    String
  code     String
  purpose  OTPPurpose @default(LOGIN)
  attempts Int        @default(0)

  expiresAt  DateTime  @map("expires_at")
  consumedAt DateTime? @map("consumed_at")

  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([phone, purpose])
  @@index([userId])
  @@map("otp_codes")
}

model TrustedDevice {
  id String @id @default(uuid()) @db.Uuid

  userId       String    @map("user_id") @db.Uuid
  deviceId     String    @map("device_id")
  userAgent    String?   @map("user_agent")
  ipAddress    String?   @map("ip_address")
  verifiedAt   DateTime  @default(now()) @map("verified_at")
  lastSeenAt   DateTime  @default(now()) @map("last_seen_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceId])
  @@index([userId])
  @@map("trusted_devices")
}

model Review {
  id String @id @default(uuid()) @db.Uuid

  carRentalId  String          @map("car_rental_id") @db.Uuid
  reviewerId   String          @map("reviewer_id") @db.Uuid
  targetUserId String          @map("target_user_id") @db.Uuid
  carId        String?         @map("car_id") @db.Uuid
  direction    ReviewDirection

  rating  Int
  comment String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  rental     CarRental @relation(fields: [carRentalId], references: [id], onDelete: Cascade)
  reviewer   User      @relation("Reviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
  targetUser User      @relation("ReviewTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  car Car? @relation(fields: [carId], references: [id], onDelete: SetNull)

  @@unique([carRentalId, direction])
  @@index([targetUserId])
  @@index([reviewerId])
  @@map("reviews")
}

model Notification {
  id String @id @default(uuid()) @db.Uuid

  receiverId    String  @map("receiver_id") @db.Uuid
  triggerUserId String? @map("trigger_user_id") @db.Uuid

  title   String
  message String

  type     String?
  entityId String? @map("entity_id") @db.Uuid

  isRead Boolean @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  receiver    User  @relation("NotificationReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  triggerUser User? @relation("NotificationTrigger", fields: [triggerUserId], references: [id], onDelete: SetNull)

  @@index([receiverId])
  @@index([entityId])
  @@map("notifications")
}

model Session {
  id        String   @id @default(uuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(uuid())
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verifications")
}
